# Generated Xcode project (regenerated by `xcodegen generate` on CI)
*.xcodeproj/
*.xcworkspace/

# Secrets / signing (CI writes Config/Signing.xcconfig from secrets)
Config/Signing.xcconfig

# gomobile output (built on the CI macOS runner from Vendor/bidichan-src/mobile)
Vendor/Bidichan.xcframework/

# Build artifacts
build/
DerivedData/
*.ipa
*.xcarchive
manifest.plist

# SwiftPM
.build/
.swiftpm/

# fastlane artifacts
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/README.md

# Device list is generated on CI from the DEVICE_UDIDS secret — never commit it
# (a UDID in a public repo is a persistent device fingerprint).
fastlane/devices.txt

# macOS
.DS_Store
