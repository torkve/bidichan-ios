default_platform(:ios)

APP_ID    = "torkve.bidichan"
TUNNEL_ID = "torkve.bidichan.tunnel"
APP_GROUP = "group.torkve.bidichan"
ROOT      = File.expand_path("..", __dir__)
PROJECT   = File.join(ROOT, "bidichan.xcodeproj")

# App Store Connect API key from base64 secret (Team key, App Manager role).
# set_spaceship_token authorizes Spaceship globally, so actions that don't take
# an `api_key:` param (produce) still authenticate via the key.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
    is_key_content_base64: true,
    in_house: false,
    set_spaceship_token: true
  )
end

# Writes the signing xcconfig XcodeGen reads (git-ignored). profile_type is the
# match profile prefix ("AppStore" or "AdHoc").
def write_signing_xcconfig(profile_type)
  build_number = ENV["BUILD_NUMBER"] || "1"
  File.write(File.join(ROOT, "Config/Signing.xcconfig"), <<~CFG)
    // Generated by fastlane — do not commit.
    DEVELOPMENT_TEAM = #{ENV.fetch('APPLE_TEAM_ID')}
    PP_APP = match #{profile_type} #{APP_ID}
    PP_TUNNEL = match #{profile_type} #{TUNNEL_ID}
    CURRENT_PROJECT_VERSION = #{build_number}
  CFG
end

def generate_project
  sh("cd #{ROOT.shellescape} && xcodegen generate")
end

def gym_build(export_method:, profile_type:)
  build_app(
    project: PROJECT,
    scheme: "bidichan",
    configuration: "Release",
    export_method: export_method,
    output_directory: File.join(ROOT, "build"),
    output_name: "bidichan.ipa",
    clean: true,
    export_options: {
      signingStyle: "manual",
      provisioningProfiles: {
        APP_ID    => "match #{profile_type} #{APP_ID}",
        TUNNEL_ID => "match #{profile_type} #{TUNNEL_ID}"
      }
    }
  )
end

platform :ios do
  before_all do
    setup_ci
  end

  # -------------------------------------------------------------- one-time bootstrap
  desc "One-time: register bundle IDs + capabilities, devices, and create certs/profiles"
  lane :bootstrap do
    key = asc_api_key

    # Main app: create the App Store Connect record + portal id with the
    # App Groups and Network Extensions capabilities. produce takes no api_key
    # param — it authenticates via the global Spaceship token set above.
    produce(
      app_identifier: APP_ID,
      app_name: "bidichan",
      enable_services: { app_group: "on", network_extension: "on" }
    )
    # Tunnel extension: portal identifier only (no App Store record), same caps.
    produce(
      app_identifier: TUNNEL_ID,
      app_name: "bidichan tunnel",
      skip_itc: true,
      enable_services: { app_group: "on", network_extension: "on" }
    )

    register_devices(devices_file: File.join(ROOT, "fastlane/devices.txt"), api_key: key) if File.exist?(File.join(ROOT, "fastlane/devices.txt"))

    %w[development appstore adhoc].each do |t|
      match(type: t, app_identifier: [APP_ID, TUNNEL_ID], api_key: key,
            readonly: false, force_for_new_devices: true)
    end
    UI.message("Bootstrap done. If signing complains about the App Group, run `fastlane app_groups` (see SETUP.md).")
  end

  # Create + associate the App Group. Kept separate because group management can
  # require an Apple-ID session (app-specific password) rather than the API key.
  desc "Create and associate the App Group on both bundle IDs"
  lane :app_groups do
    sh("fastlane produce group -g #{APP_GROUP} -n 'bidichan app group' || true")
    sh("fastlane produce associate_group -a #{APP_ID} #{APP_GROUP} || true")
    sh("fastlane produce associate_group -a #{TUNNEL_ID} #{APP_GROUP} || true")
  end

  # -------------------------------------------------------------- TestFlight (internal)
  desc "Build and upload to TestFlight (internal testers)"
  lane :beta do
    key = asc_api_key
    match(type: "appstore", app_identifier: [APP_ID, TUNNEL_ID], api_key: key, readonly: true)
    write_signing_xcconfig("AppStore")
    generate_project
    gym_build(export_method: "app-store", profile_type: "AppStore")
    upload_to_testflight(
      api_key: key,
      distribute_external: false,
      skip_waiting_for_build_processing: true,
      ipa: File.join(ROOT, "build/bidichan.ipa")
    )
  end

  # -------------------------------------------------------------- ad-hoc (OTA)
  desc "Build an ad-hoc IPA for OTA install (manifest generated by the workflow)"
  lane :adhoc do
    key = asc_api_key
    match(type: "adhoc", app_identifier: [APP_ID, TUNNEL_ID], api_key: key, readonly: true)
    write_signing_xcconfig("AdHoc")
    generate_project
    gym_build(export_method: "ad-hoc", profile_type: "AdHoc")
  end
end
