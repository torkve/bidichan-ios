default_platform(:ios)

APP_ID    = "torkve.bidichan"
TUNNEL_ID = "torkve.bidichan.tunnel"
APP_GROUP = "group.torkve.bidichan"
ROOT      = File.expand_path("..", __dir__)
PROJECT   = File.join(ROOT, "bidichan.xcodeproj")

# App Store Connect API key from base64 secret (Team key, App Manager role).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
    is_key_content_base64: true,
    in_house: false
  )
end

# Writes the signing xcconfig XcodeGen reads (git-ignored). profile_type is the
# match profile prefix ("AppStore" or "AdHoc").
def write_signing_xcconfig(profile_type)
  build_number = ENV["BUILD_NUMBER"] || "1"
  File.write(File.join(ROOT, "Config/Signing.xcconfig"), <<~CFG)
    // Generated by fastlane — do not commit.
    DEVELOPMENT_TEAM = #{ENV.fetch('APPLE_TEAM_ID')}
    PP_APP = match #{profile_type} #{APP_ID}
    PP_TUNNEL = match #{profile_type} #{TUNNEL_ID}
    CURRENT_PROJECT_VERSION = #{build_number}
  CFG
end

def generate_project
  sh("cd #{ROOT.shellescape} && xcodegen generate")
end

def gym_build(export_method:, profile_type:)
  build_app(
    project: PROJECT,
    scheme: "bidichan",
    configuration: "Release",
    export_method: export_method,
    output_directory: File.join(ROOT, "build"),
    output_name: "bidichan.ipa",
    clean: true,
    export_options: {
      signingStyle: "manual",
      provisioningProfiles: {
        APP_ID    => "match #{profile_type} #{APP_ID}",
        TUNNEL_ID => "match #{profile_type} #{TUNNEL_ID}"
      }
    }
  )
end

platform :ios do
  before_all do
    setup_ci
  end

  # -------------------------------------------------------------- one-time bootstrap
  # Prereq (one-time, in the Apple web portals — see SETUP.md "Portal setup"):
  # both bundle IDs with App Groups + Network Extensions capabilities, the App
  # Group group.torkve.bidichan assigned to both, and the App Store Connect app
  # record. Those cannot be created headlessly with only an API key (the ASC API
  # has no app-creation endpoint and app groups aren't in it), so this lane does
  # only what the API key can do: register devices and create/store signing.
  desc "One-time: register devices and create/store certs & profiles (see SETUP.md)"
  lane :bootstrap do
    key = asc_api_key

    register_devices(devices_file: File.join(ROOT, "fastlane/devices.txt"), api_key: key) if File.exist?(File.join(ROOT, "fastlane/devices.txt"))

    %w[development appstore adhoc].each do |t|
      match(type: t, app_identifier: [APP_ID, TUNNEL_ID], api_key: key,
            readonly: false, force_for_new_devices: true)
    end
    UI.success("Certs & profiles pushed to the match repo. If a profile failed to " \
               "generate, finish the Portal setup in SETUP.md (bundle IDs + " \
               "capabilities + App Group).")
  end

  # Revoke ALL development + distribution certificates and their match profiles.
  # Use this to clear orphans left by failed bootstrap runs (which create a cert
  # in the portal before dying, eventually hitting Apple's per-account cert
  # limit). Safe on a fresh account used only for this app; run `bootstrap`
  # afterward to mint fresh, repo-stored certs.
  desc "Revoke all dev/distribution certs & profiles (clears orphans from failed runs)"
  lane :nuke do
    key = asc_api_key
    %w[development distribution].each do |t|
      match_nuke(type: t, api_key: key, skip_confirmation: true)
    end
  end

  # -------------------------------------------------------------- TestFlight (internal)
  desc "Build and upload to TestFlight (internal testers)"
  lane :beta do
    key = asc_api_key
    match(type: "appstore", app_identifier: [APP_ID, TUNNEL_ID], api_key: key, readonly: true)
    write_signing_xcconfig("AppStore")
    generate_project
    gym_build(export_method: "app-store", profile_type: "AppStore")
    upload_to_testflight(
      api_key: key,
      distribute_external: false,
      skip_waiting_for_build_processing: true,
      ipa: File.join(ROOT, "build/bidichan.ipa")
    )
  end

  # -------------------------------------------------------------- ad-hoc (OTA)
  desc "Build an ad-hoc IPA for OTA install (manifest generated by the workflow)"
  lane :adhoc do
    key = asc_api_key
    match(type: "adhoc", app_identifier: [APP_ID, TUNNEL_ID], api_key: key, readonly: true)
    write_signing_xcconfig("AdHoc")
    generate_project
    gym_build(export_method: "ad-hoc", profile_type: "AdHoc")
  end
end
